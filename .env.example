# ============================
# SNDP Survey Project - Env
# ============================

# --- Turso Database (Production - Required for Vercel/Render) ---
# Create a free account at https://turso.tech
# Then run: turso db create sndp-survey
# Get URL: turso db show sndp-survey --url
# Get Token: turso db tokens create sndp-survey
TURSO_DATABASE_URL=libsql://your-database-name-yourusername.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# --- App Settings ---
NODE_ENV=production
PORT=3000
